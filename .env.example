# 자동화 브라우저: chrome | msedge  (개인 크롬과 오디오 분리하려면 msedge)
BROWSER=chrome

# 관찰할 동영상 페이지 URL (스파이크용). 비워두면 https://www.naver.com 으로 시작.
TARGET_URL=

# --- OBS (아직 스파이크 단계에선 사용 안 함. 이후 레코더에서 사용) ---
OBS_WS_URL=ws://127.0.0.1:4455
OBS_WS_PASSWORD=

# 녹화 결과를 옮겨둘 폴더
RECORD_DIR=./recordings

# (선택) OBS 장면 이름 — 지정하면 녹화 전 이 장면으로 전환
OBS_SCENE=

# (테스트용) >0 이면 영상이 안 끝나도 이 초수에서 녹화 강제 종료. 첫 검증엔 60 추천. 실제 운영은 비워두기.
MAX_RECORD_SEC=

# ntfy 푸시 알림 토픽 (비우면 알림 끔). 폰 ntfy 앱에서 같은 토픽 구독.
NTFY_TOPIC=

# 구글 드라이브 루트 폴더명 (필수 — 없으면 실행 거부). 아래에 catalog별 하위폴더 생성.
GDRIVE_ROOT=npc

# 구글 OAuth (drive.file 스코프). GCP 콘솔 OAuth(Desktop) 발급 → login 으로 refresh token 획득.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
